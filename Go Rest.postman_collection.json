    {
      "name": "Get User by id (Happy Case)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//1.Validate status code",
              "pm.test(\"Response status code is 200 OK\", function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "//2.Validate correct user data",
              "var jsonData = pm.response.json();",
              "",
              "console.log(typeof jsonData.id); ",
              "",
              "pm.test(\"Validate correct user data and data type\" ,function (){",
              "    //ตรวจสอบ id ตรงกันที่ create มาล่าสุด",
              "    pm.expect(jsonData.id).to.be.a('number');",
              "    pm.expect(jsonData.id).to.eql(parseInt(pm.environment.get(\"current_user_id\")));",
              "",
              "    //ตรวจสอบ name",
              "    pm.expect(jsonData.name).to.be.a('string');",
              "    //ตรวจสอบ email",
              "    pm.expect(jsonData.email).to.be.a('string');",
              "    //ตรวจสอบ gender",
              "    pm.expect(jsonData.gender).to.be.a('string')",
              "    pm.expect(jsonData.gender).to.be.oneOf([\"male\",\"female\"])",
              "    //ตรวจสอบ status",
              "    pm.expect(jsonData.status).to.be.a('string')",
              "    pm.expect(jsonData.status).to.be.oneOf([\"active\",\"inactive\"])",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
