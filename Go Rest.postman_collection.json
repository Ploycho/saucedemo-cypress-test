  "item": [
    {
      "name": "Create User (Happy Case)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "//1.Validate status code",
              "pm.test(\"Response status code is 201 Created\" , function(){",
              "    pm.expect(pm.response.code).to.eql(201);",
              "});",
              "",
              "//2.Validate response schema",
              "var jsonData = pm.response.json();",
              "",
              "pm.test(\"Response schema is valid\" , function (){",
              "    pm.expect(jsonData).to.have.property('id');",
              "    pm.expect(jsonData).to.have.property('name');",
              "    pm.expect(jsonData).to.have.property('email');",
              "    pm.expect(jsonData).to.have.property('gender');",
              "    pm.expect(jsonData).to.have.property('status');",
              "});",
              "",
              "//3.Validate auto-generated user ID",
              "console.log(typeof jsonData.id);",
              "",
              "pm.test(\"Validate auto-generated user ID\" , function (){",
              "    pm.expect(jsonData.id).to.be.a('number');",
              "    pm.expect(jsonData.id).to.not.be.null;",
              "});",
              "",
              "//4.Validate User detail",
              "var requestData = JSON.parse(pm.request.body.raw)",
              "pm.test(\"Validate user detail are correct\" , function() {",
              "    pm.expect(jsonData.name).to.eql(requestData.name)",
              "    pm.expect(jsonData.gender).to.eql(requestData.gender)",
              "    pm.expect(jsonData.status).to.eql(requestData.status)",
              "    pm.expect(jsonData.email).to.include(\"PloyQA.\")",
              "});",
              "",
              "if (pm.response.code === 201) {",
              "    pm.environment.set(\"current_user_id\", jsonData.id);",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
